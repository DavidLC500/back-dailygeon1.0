# Puerto del servidor Express
PORT=4000

# Cadena de conexion a MongoDB.
# - Local (Docker):  mongodb://127.0.0.1:27017/dailygeon
# - Atlas (nube):    mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/dailygeon?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/dailygeon

# Secreto para firmar los tokens JWT (cambialo por una cadena larga y aleatoria)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Caducidad del token de sesion
JWT_EXPIRES_IN=7d

# Origen permitido para CORS (la URL del frontend)
CLIENT_URL=http://localhost:5173
